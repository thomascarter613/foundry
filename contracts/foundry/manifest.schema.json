{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foundry.dev/schemas/foundry-manifest.schema.json",
  "title": "Foundry Manifest",
  "description": "Repository-local lifecycle manifest for Foundry-managed workspaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "foundryVersion",
    "workspace",
    "lifecycle",
    "verification",
    "audit",
    "ai"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "foundryVersion": {
      "type": "string",
      "minLength": 1
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "packageManager",
        "sourceOfTruth"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "monorepo",
            "single-package",
            "service",
            "application",
            "library",
            "unknown"
          ]
        },
        "packageManager": {
          "type": "string",
          "enum": [
            "bun",
            "pnpm",
            "npm",
            "yarn",
            "unknown"
          ]
        },
        "sourceOfTruth": {
          "type": "string",
          "enum": [
            "repository",
            "remote-control-plane",
            "hybrid"
          ]
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "supportedEvents",
        "defaultFlow"
      ],
      "properties": {
        "model": {
          "type": "string",
          "const": "inspect-resolve-plan-apply-verify-document-audit-handoff"
        },
        "supportedEvents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "init",
              "add",
              "upgrade",
              "migrate",
              "repair",
              "validate",
              "doctor",
              "audit",
              "plan",
              "spec",
              "ai",
              "handoff"
            ]
          },
          "uniqueItems": true
        },
        "defaultFlow": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "inspect",
              "resolve",
              "plan",
              "apply",
              "verify",
              "document",
              "audit",
              "handoff"
            ]
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationCommand"
          }
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "logPath",
        "eventSchemaVersion"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "logPath": {
          "type": "string",
          "minLength": 1
        },
        "eventSchemaVersion": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "ai": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "providerRequired",
        "artifacts"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "manual",
            "optional-provider",
            "configured-provider"
          ]
        },
        "providerRequired": {
          "type": "boolean"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/aiArtifact"
          }
        }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "database": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/providerReference"
          }
        },
        "ai": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/providerReference"
          }
        }
      }
    }
  },
  "$defs": {
    "verificationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "command",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "aiArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "purpose"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "providerReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "source": {
          "type": "string",
          "enum": [
            "built-in",
            "external",
            "local",
            "remote"
          ]
        }
      }
    }
  }
}
