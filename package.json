{
  "name": "myapp",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "tools/*",
    "templates/*",
    "docs/*"
  ],
  "scripts": {
    "verify": "bash tools/scripts/verify.sh",
    "verify:contracts": "bash tools/scripts/verify-contracts.sh",
    "verify:generated": "bash tools/scripts/verify-generated.sh",
    "verify:generators": "bash tools/scripts/verify-generators.sh",
    "foundry": "cd packages/cli && bun run foundry",
    "foundry:build": "cd packages/cli && bun run build",
    "foundry:typecheck": "cd packages/cli && bun run typecheck"
  },
  "devDependencies": {
    "@redocly/cli": "^2.30.3",
    "@types/bun": "latest",
    "orval": "^8.9.1",
    "plop": "^4.0.5",
    "scaffdog": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
