{
  "name": "foundry",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "tools/*",
    "templates/*",
    "docs/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/cli build",
    "foundry": "bash tools/scripts/foundry.sh",
    "foundry:build": "cd packages/cli && bun run build",
    "foundry:typecheck": "cd packages/cli && bun run typecheck",
    "typecheck": "bun run --cwd packages/cli typecheck",
    "verify": "bun run typecheck && bun run build && bun run verify:docs && bash tools/scripts/verify.sh",
    "verify:contracts": "bash tools/scripts/verify-contracts.sh",
    "verify:docs": "bun run tools/scripts/verify-docs.ts",
    "verify:generated": "bash tools/scripts/verify-generated.sh",
    "verify:generator-manifest": "bash tools/scripts/verify-generator-manifest.sh",
    "verify:generators": "bash tools/scripts/verify-generators.sh",
    "verify:init": "bash tools/scripts/verify-init.sh",
    "verify:init-external-provider-plugins": "bash tools/scripts/verify-init-external-provider-plugins.sh",
    "verify:init-provider-plugins": "bash tools/scripts/verify-init-provider-plugins.sh",
    "verify:init-upgrade": "bash tools/scripts/verify-init-upgrade.sh",
    "verify:manifest": "bash tools/scripts/verify-manifest.sh"
  },
  "devDependencies": {
    "@redocly/cli": "^2.30.3",
    "@types/bun": "latest",
    "orval": "^8.9.1",
    "plop": "^4.0.5",
    "scaffdog": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
